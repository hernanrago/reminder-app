<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground — 108×108 dp, safe zone 18–90.

  Structure:
    10 white lobe circles arranged in a ring (brain/flower shape)
      R=25 (center-to-lobe-center), r=10 (lobe radius)
      angle_i = −90° + i×36°
      i=0  (54,  29)   i=5  (54,  79)
      i=1  (68.7,33.8) i=6  (39.3,74.2)
      i=2  (77.8,46.3) i=7  (30.2,61.7)
      i=3  (77.8,61.7) i=8  (30.2,46.3)
      i=4  (68.7,74.2) i=9  (39.3,33.8)
    White inner fill circle r=21 (seals the gap between lobes)
    Teal bezel ring r=19 (same color as background → appears as clock ring)
    Navy center dot r=2.5
    Navy clock hands (hour → ~10:10, minute → ~10 min)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── 10 brain/flower lobe circles ── -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M 44,29 a 10,10 0 1 0 20,0 a 10,10 0 1 0 -20,0"/>
    <path android:fillColor="#FFFFFF"
        android:pathData="M 58.7,33.8 a 10,10 0 1 0 20,0 a 10,10 0 1 0 -20,0"/>
    <path android:fillColor="#FFFFFF"
        android:pathData="M 67.8,46.3 a 10,10 0 1 0 20,0 a 10,10 0 1 0 -20,0"/>
    <path android:fillColor="#FFFFFF"
        android:pathData="M 67.8,61.7 a 10,10 0 1 0 20,0 a 10,10 0 1 0 -20,0"/>
    <path android:fillColor="#FFFFFF"
        android:pathData="M 58.7,74.2 a 10,10 0 1 0 20,0 a 10,10 0 1 0 -20,0"/>
    <path android:fillColor="#FFFFFF"
        android:pathData="M 44,79 a 10,10 0 1 0 20,0 a 10,10 0 1 0 -20,0"/>
    <path android:fillColor="#FFFFFF"
        android:pathData="M 29.3,74.2 a 10,10 0 1 0 20,0 a 10,10 0 1 0 -20,0"/>
    <path android:fillColor="#FFFFFF"
        android:pathData="M 20.2,61.7 a 10,10 0 1 0 20,0 a 10,10 0 1 0 -20,0"/>
    <path android:fillColor="#FFFFFF"
        android:pathData="M 20.2,46.3 a 10,10 0 1 0 20,0 a 10,10 0 1 0 -20,0"/>
    <path android:fillColor="#FFFFFF"
        android:pathData="M 29.3,33.8 a 10,10 0 1 0 20,0 a 10,10 0 1 0 -20,0"/>

    <!-- ── White inner fill (fills the gap between lobes, r=21) ── -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M 33,54 a 21,21 0 1 0 42,0 a 21,21 0 1 0 -42,0"/>

    <!-- ── Clock bezel ring: teal stroke at r=19 ── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#2BABB8"
        android:strokeWidth="2"
        android:pathData="M 35,54 a 19,19 0 1 0 38,0 a 19,19 0 1 0 -38,0"/>

    <!-- ── Navy hour hand  (~10:10 → upper-left, length=11) ── -->
    <!-- angle 214.9° in screen coords → end (45, 47.7) -->
    <path
        android:strokeColor="#1B3A6B"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 54,54 L 45,47.7"/>

    <!-- ── Navy minute hand (~10 min → upper-right, length=15) ── -->
    <!-- angle 330° in screen coords → end (67, 46.5) -->
    <path
        android:strokeColor="#1B3A6B"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 54,54 L 67,46.5"/>

    <!-- ── Navy center dot (r=2.5) ── -->
    <path android:fillColor="#1B3A6B"
        android:pathData="M 51.5,54 a 2.5,2.5 0 1 0 5,0 a 2.5,2.5 0 1 0 -5,0"/>

</vector>
